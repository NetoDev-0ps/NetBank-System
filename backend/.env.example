# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Banco (DEV no Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bancodigital_db
DB_USER=postgres
DB_PASSWORD=Admin

# JWT
JWT_SECRET=gere-uma-chave-com-32-ou-mais-caracteres-aleatorios
JWT_PREVIOUS_SECRETS=
JWT_EXP_MINUTES=60
JWT_ISSUER=netbank-api

# Admin bootstrap (gerente)
ADMIN_NAME=Administrador Master
ADMIN_EMAIL=admin@netbank.com.br
ADMIN_PASSWORD_HASH=COLE_AQUI_O_HASH_BCRYPT

# Cookie de autenticacao
AUTH_COOKIE_NAME=NETBANK_AUTH
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Strict
AUTH_COOKIE_PATH=/

# Captcha humano
AUTH_CAPTCHA_ENABLED=true
AUTH_CAPTCHA_CHALLENGE_TTL_SECONDS=180
AUTH_CAPTCHA_PROOF_TTL_SECONDS=120
AUTH_CAPTCHA_TOLERANCE=4
AUTH_CAPTCHA_MIN_VALUE=0
AUTH_CAPTCHA_MAX_VALUE=100

# Protecao anti-bruteforce de login
AUTH_LOGIN_PROTECTION_ENABLED=true
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_ATTEMPT_WINDOW_MINUTES=15
AUTH_LOGIN_LOCK_MINUTES=15

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Flyway (DEV - estrito, sem baseline implicito)
FLYWAY_BASELINE_ON_MIGRATE=false
